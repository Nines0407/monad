# Audit System Configuration

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/agent_pay_audit"
DATABASE_TEST_URL="postgresql://postgres:password@localhost:5432/agent_pay_audit_test"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=3001
NODE_ENV="development"

# Security
JWT_SECRET="your_jwt_secret_key_change_in_production"
ENCRYPTION_KEY="generate_with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""

# Audit System
AUDIT_RETENTION_DAYS=365
EXPORT_MAX_RECORDS=100000

# Monad (if needed)
MONAD_RPC_URL="https://testnet.monad.xyz"
MONAD_CHAIN_ID=10143

# Logging
LOG_LEVEL="info"
LOG_TO_FILE="false"
LOG_FILE_PATH="./logs/audit.log"