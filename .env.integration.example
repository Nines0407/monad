# Integration Layer Configuration

# MCP服务器配置
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost
MCP_MAX_CONNECTIONS=100
MCP_HEARTBEAT_INTERVAL=30
MCP_AUTH_ENABLED=true
MCP_TOKEN_EXPIRY=3600

# API服务器配置
API_PORT=3001
API_HOST=localhost
API_RATE_LIMIT=1000
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# WebSocket配置
WS_PORT=3002
WS_HOST=localhost
WS_MAX_CONNECTIONS=10000
WS_PING_INTERVAL=30

# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/agent_pay_integration
DB_POOL_SIZE=10
DB_SSL=false

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=agent_pay:

# Monad配置
MONAD_RPC_URL=https://testnet.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://explorer.monad.xyz
CONTRACT_ADDRESS=

# 安全配置
ENCRYPTION_KEY=generate_with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production
SESSION_EXPIRY=86400

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003

# 日志配置
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/integration.log