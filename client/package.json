{
  "name": "agentic-payment-client",
  "version": "1.0.0",
  "description": "Local client application for Agentic Payment System",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "clean": "rm -rf dist",
    "prepack": "npm run build",
    "setup": "../scripts/setup.sh",
    "health-check": "node scripts/health-check.js"
  },
  "keywords": [
    "monad",
    "blockchain",
    "payment",
    "agent",
    "security",
    "session-keys"
  ],
  "author": "AI Agent",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {

    "ethers": "^6.13.5",
    "@walletconnect/modal": "^2.7.0",
    "@openzeppelin/contracts": "^5.2.0",
    "@noble/ed25519": "^2.0.0",


    "sqlite3": "^5.1.7",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}