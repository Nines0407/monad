{
  "name": "agentic-payment-system",
  "version": "0.1.0",
  "description": "Agent-native secure payment system on Monad blockchain with audit system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate:up": "ts-node scripts/migrate.ts up",
    "migrate:down": "ts-node scripts/migrate.ts down",
    "generate:docs": "typedoc --out docs/api src/",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "contracts:coverage": "cd contracts && forge coverage",
    "contracts:deploy": "cd contracts && forge script script/Deploy.s.sol --rpc-url $MONAD_RPC_URL --broadcast",
    "health-check": "bash scripts/health-check.sh",
    "dev:integration": "concurrently \"npm run dev:mcp\" \"npm run dev:api\" \"npm run dev:ws\"",
    "build:integration": "npm run build:mcp && npm run build:cli && npm run build:sdk && npm run build:api && npm run build:ws",
    "test:integration": "npm run test:mcp && npm run test:cli && npm run test:sdk && npm run test:api && npm run test:ws",
    "dev:mcp": "ts-node-dev integration/mcp-server/src/index.ts",
    "build:mcp": "tsc --project integration/mcp-server/tsconfig.json",
    "start:mcp": "node integration/mcp-server/dist/index.js",
    "test:mcp": "cd integration/mcp-server && npm test",
    "dev:cli": "ts-node-dev integration/cli/src/cli.ts",
    "build:cli": "tsc --project integration/cli/tsconfig.json",
    "test:cli": "cd integration/cli && npm test",
    "build:sdk": "tsc --project integration/sdk/tsconfig.json && tsup integration/sdk/src/index.ts --format cjs,esm --dts",
    "test:sdk": "cd integration/sdk && npm test",
    "dev:api": "ts-node-dev integration/api/src/index.ts",
    "build:api": "tsc --project integration/api/tsconfig.json",
    "start:api": "node integration/api/dist/index.js",
    "test:api": "cd integration/api && npm test",
    "dev:ws": "ts-node-dev integration/websocket/src/index.ts",
    "build:ws": "tsc --project integration/websocket/tsconfig.json",
    "start:ws": "node integration/websocket/dist/index.js",
    "test:ws": "cd integration/websocket && npm test",
    "docs:integration": "bash scripts/generate-integration-docs.sh",
    "deploy:integration": "bash scripts/deploy-integration.sh",
    "health-check:integration": "bash scripts/health-check-integration.sh",
    "deploy:contracts": "npm run contracts:deploy",
    "deploy:backend": "npm run build && npm start",
    "deploy:mcp": "npm run start:mcp",
    "deploy:all": "bash scripts/deploy-all.sh",
    "update-preset": "echo 'Update agent_development_preset.md with current practices'",
    "validate-preset": "node scripts/verify-preset.js"
  },
  "dependencies": {
    "@fastify/websocket": "^8.3.0",
    "@graphql-tools/load": "^8.0.0",
    "@graphql-tools/schema": "^10.0.0",
    "@modelcontextprotocol/sdk": "^0.6.0",
    "apollo-server-express": "^3.13.0",
    "axios": "^1.6.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fastify": "^4.24.3",
    "graphql": "^16.8.1",
    "graphql-yoga": "^5.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "prisma": "^5.7.0",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@fastify/type-provider-typebox": "^3.1.0",
    "@types/commander": "^2.12.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.7",
    "@types/socket.io": "^3.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "graphql-markdown": "^7.3.0",
    "jest": "^29.7.0",
    "oclif": "^3.11.0",
    "redoc": "^2.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.0.1",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "monad",
    "blockchain",
    "payment",
    "agent",
    "audit"
  ],
  "author": "Agentic Payment System Team",
  "license": "MIT"
}
